# REZIQ — Environment Variables Template

# 1. Supabase Connection details
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# 2. Groq LLM API Keys (Primary & Fallback)
GROQ_API_KEY_PRIMARY=YOUR_PRIMARY_GROQ_API_KEY
GROQ_API_KEY_SECONDARY=YOUR_SECONDARY_GROQ_API_KEY
GROQ_API_KEY=YOUR_PRIMARY_GROQ_API_KEY

# 3. Resend Email Telemetry
RESEND_API_KEY=YOUR_RESEND_API_KEY
FEEDBACK_RECEIVER_EMAIL=shivamaniforwork@gmail.com

# 4. Routing Ports and Server URLs
NEXT_PUBLIC_API_URL=https://reziqai.vercel.app/_/backend
NEXT_PUBLIC_APP_URL=https://reziqai.vercel.app
FASTAPI_SERVER_URL=https://reziqai.vercel.app/_/backend
